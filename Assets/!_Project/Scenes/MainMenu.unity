  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Checkout: there customers can buy food.

    Kitchen:  supplies the cafe
    with food. Accepts raw food crates for a large amount of money. Pollutes the
    environment if the refinery is not built.

    Customer invitation spot: invites
    customers when interacted. Can invite only one customer per a certain amount
    of time.

    Waste bin (black): accepts small food waste. Creates a black waste
    box once fully loaded.

    Sorting bin (yellow): accepts recyclable waste. When
    fully loaded creates a waste box of one of three types: paper, plastic or organic.
    Note that not every small litter box can be accepted by sorting bin, so some
    of the customers would drop their waste if the black waste bin is not built.

    Refinery:
    removes the kitchen pollution.

    Waste collection points (organic, paper,
    plastic): accept corresponding litter types.

    Garbage truck: accepts any
    types of waste. After waiting for the cafe manager to clean the area, it will
    automatically remove all the waste inside fining you for every litter box left.

    Building
    spots: improvements can be built there for some amount of money.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: e66bb29cbbca3674fb7f486af37aee9f, type: 2}
  m_sharedMaterial: {fileID: 2720382059998863878, guid: e66bb29cbbca3674fb7f486af37aee9f, type: 2}
